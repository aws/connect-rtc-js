{
  "name": "@aws/connect-rtc-js",
  "version": "1.3.2",
  "description": "Amazon Connect softphone library",
  "license": "Apache-2.0",
  "main": "./release/connect-rtc.js",
  "files": [
    "/release",
    "NOTICE.txt",
    "THIRD-PARTY.txt"
  ],
  "keywords": [
    "amazon-connect",
    "softphone",
    "webrtc",
    "rtc"
  ],
  "authors": {
    "name": "Amazon Web Services",
    "email": "",
    "url": "http://aws.amazon.com/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aws/connect-rtc-js.git"
  },
  "homepage": "https://github.com/aws/connect-rtc-js#readme",
  "contributors": [
    "Yuliang Zhou <yuliangz@amazon.com>",
    "Anil Kumar Vuta <anilvuta@amazon.com>"
  ],
  "scripts": {
    "preversion": "git stash && git checkout master && git pull && npm test && git checkout -B bumpVersion",
    "version": "grunt build && grunt copyForPublish && git add package.json release/* ",
    "postversion": "export GITTAG=\"echo $(git describe --abbrev=0 --tags | sed 's/^v//')\" && git push --force --set-upstream origin bumpVersion --follow-tags && git checkout gh-pages && git pull && cp out/connect-rtc-debug.js ./connect-rtc-debug-`$GITTAG`.js && cp out/connect-rtc.min.js ./connect-rtc-`$GITTAG`.min.js && ln -fs connect-rtc-debug-`$GITTAG`.js connect-rtc-debug-latest.js && ln -fs connect-rtc-`$GITTAG`.min.js connect-rtc-latest.min.js && git add connect-rtc*.js && git commit -m `$GITTAG` && git push --set-upstream origin gh-pages && git checkout master",
    "prepublish": "tsc && grunt build",
    "release": "tsc && grunt build",
    "grunt": "grunt build",
    "test": "grunt && npm run-script unitTest && npm run-script integTest && npm run-script combineTestReports",
    "unitTest": "nyc mocha --file test/unit/test-setup.ts --require ts-node/register test/unit/**/*.ts test/unit/*.ts",
    "integTest": "nyc --no-clean mocha --exit --require ts-node/register --require test/integration/test-setup.ts test/integration/*.spec.ts",
    "combineTestReports": "nyc report --report-dir=./build/coverage --reporter=cobertura --reporter=html"
  },
  "_ucsdk_upgrade_note": "Please follow the instruction here(https://tiny.amazon.com/18mszf5px/quipaTMFStep) to upgrade @citrix/ucsdk",
  "dependencies": {
    "@citrix/ucsdk": "3.1.0",
    "@citrix/ucsdk_4.1": "npm:@citrixcloud/ucsdk@4.1.3",
    "ua-parser-js": "^1.0.39",
    "uuid": "^3.0.1",
    "webrtc-adapter": "^6.4.0",
    "@euc-releases/horizon-webrtc-redir-sdk": "^8.15.0"
  },
  "engines": {
    "npm": ">=3.10.0",
    "node": ">=6.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@roamhq/wrtc": "^0.9.1",
    "@salesforce/ts-sinon": "1.4.31",
    "@types/chai": "^5.2.2",
    "@types/jsdom": "^27.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.5.2",
    "@types/node-turn": "^0.0.5",
    "@types/semver": "^7.7.1",
    "@types/sinon": "^17.0.4",
    "@types/sinon-chai": "^4.0.0",
    "@types/uuid": "^11.0.0",
    "@types/webrtc": "^0.0.46",
    "babel-plugin-transform-runtime": "^6.23.0",
    "babel-polyfill": "^6.23.0",
    "babel-preset-env": "^1.3.2",
    "babelify": "^7.3.0",
    "chai": "^6.0.1",
    "eslint-config-webrtc": "^1.0.0",
    "faucet": "0.0.1",
    "grunt": "^1.5.3",
    "grunt-browserify": "^5.3.0",
    "grunt-cli": "^1.0.0",
    "grunt-contrib-clean": "^1.0.0",
    "grunt-contrib-connect": "^1.0.2",
    "grunt-contrib-copy": "^1.0.0",
    "grunt-contrib-uglify": "^2.2.1",
    "grunt-contrib-uglify-es": "^3.3.0",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-eslint": "^21.0.0",
    "grunt-githooks": "^0.6.0",
    "grunt-replace": "^2.0.2",
    "jsdom": "^27.0.1",
    "mocha": "^11.7.2",
    "node-turn": "^0.0.6",
    "nyc": "^15.1.0",
    "selenium-webdriver": "^3.3.0",
    "sinon": "^21.0.0",
    "sinon-chai": "^4.0.1",
    "tape": "^4.6.3",
    "travis-multirunner": "^3.1.0",
    "ts-node": "^10.9.2",
    "tsify": "^5.0.4",
    "typescript": "^5.9.2",
    "webpack": "^5.104.1"
  }
}